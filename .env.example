# Email Configuration for Contact Form
# To enable email functionality, add your Gmail credentials below

# Your Gmail email address
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# To create an app password:
# 1. Go to myaccount.google.com
# 2. Select Security in the left navigation pane
# 3. Select App Passwords (you may need to enable 2FA first)
# 4. Select Mail and Windows Computer
# 5. Copy the generated 16-character password below
EMAIL_PASSWORD=your-16-char-app-password
